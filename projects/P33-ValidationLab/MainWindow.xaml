<Window x:Class="PracticeFA.P33.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P33 — Validation lab"
        Height="560" Width="760"
        WindowStartupLocation="CenterScreen"
        x:Name="RootWindow">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Employee edit + validation"/>
            <TextBlock Margin="0,4,0,16" Foreground="#555" TextWrapping="Wrap"
                       Text="Badge required (E + 4 chars). Quantity: numeric only, 1–999. Save disabled while errors show."/>

            <TextBlock Text="Badge ID *"/>
            <TextBox Style="{StaticResource ValidatedTextBoxStyle}"
                     Margin="0,0,0,12"
                     Text="{Binding BadgeId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>

            <TextBlock Text="Display name"/>
            <TextBox Style="{StaticResource ValidatedTextBoxStyle}"
                     Margin="0,0,0,12"
                     Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Department / work center"/>
            <TextBox Style="{StaticResource ValidatedTextBoxStyle}"
                     Margin="0,0,0,12"
                     Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Quantity * (1–999)"/>
            <TextBox x:Name="QuantityBox"
                     Style="{StaticResource ValidatedTextBoxStyle}"
                     Margin="0,0,0,16"
                     Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}"/>

            <StackPanel Orientation="Horizontal">
                <Button x:Name="SaveSnapshotButton" Margin="0,0,8,0" Padding="14,8"
                        Content="Save snapshot" Click="SaveSnapshot_Click"/>
                <Button Padding="14,8" Content="Revert" Click="Revert_Click"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" Margin="0,12,0,0" Foreground="#0066AA" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4"
                Padding="16" Background="#FAFAFA">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" FontSize="16" Text="Live preview"/>
                <TextBlock Margin="0,12,0,4" Foreground="#666" Text="Badge"/>
                <TextBlock FontSize="16" Text="{Binding BadgeId}"/>
                <TextBlock Margin="0,12,0,4" Foreground="#666" Text="Name"/>
                <TextBlock FontSize="16" Text="{Binding DisplayName}"/>
                <TextBlock Margin="0,12,0,4" Foreground="#666" Text="Department"/>
                <TextBlock FontSize="16" Text="{Binding Department}"/>
                <TextBlock Margin="0,12,0,4" Foreground="#666" Text="Quantity"/>
                <TextBlock FontSize="16" Text="{Binding QuantityText}"/>
                <TextBlock Margin="0,20,0,0" FontSize="11" Foreground="#888" TextWrapping="Wrap"
                           Text="Red border = Validation.ErrorTemplate. Save uses Validation.GetHasError + model.HasErrors."/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
