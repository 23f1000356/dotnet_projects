<Window x:Class="PracticeFA.P09.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P09 — DataGrid ← DataTable lab"
        Height="580" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#4E342E"
                   Text="P09 — DataGrid binding (Version A vs B)"/>
        <TextBlock Grid.Row="1" Margin="0,6,0,12" Foreground="#5D4E47" TextWrapping="Wrap"
                   x:Name="SourceText"
                   Text="Loading..."/>

        <TabControl Grid.Row="2">
            <!-- Version A: Legacy FA — DataTable.DefaultView -->
            <TabItem Header="A — DataTable.DefaultView (legacy FA)">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Margin="0,0,8,0" Padding="12,6" Background="#6D4C41" Foreground="White"
                                BorderThickness="0" Content="Reload" Click="Reload_Click"/>
                        <TextBlock VerticalAlignment="Center" Foreground="#5D4E47" TextWrapping="Wrap"
                                   Text="AutoGenerateColumns=True — new SP columns (e.g. Email) appear without new C# properties."/>
                    </StackPanel>
                    <DataGrid x:Name="LegacyGrid" Grid.Row="1" MinHeight="280"
                              AutoGenerateColumns="True" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"/>
                </Grid>
            </TabItem>

            <!-- Version B: ObservableCollection + explicit columns -->
            <TabItem Header="B — ObservableCollection (modern)">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Margin="0,0,8,0" Padding="12,6" Background="#6D4C41" Foreground="White"
                                BorderThickness="0" Content="Reload" Click="Reload_Click"/>
                        <Button Margin="0,0,8,0" Padding="12,6" Background="#6D4C41" Foreground="White"
                                BorderThickness="0" Content="Sort by name" Click="SortByName_Click"/>
                    </StackPanel>
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#5D4E47"
                                   Text="Filter name contains"/>
                        <TextBox x:Name="FilterBox" Padding="8,6"
                                 TextChanged="FilterBox_TextChanged"/>
                    </Grid>
                    <DataGrid x:Name="ModernGrid" Grid.Row="2" MinHeight="240"
                              IsReadOnly="True" CanUserSortColumns="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Badge" Binding="{Binding BadgeId}" Width="90"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                            <DataGridTextColumn Header="Work center" Binding="{Binding ProcessCenter}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
