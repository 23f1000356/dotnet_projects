<Window x:Class="PracticeFA.P01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Practice FA — P01 · Employee clock-in board"
        Height="560" Width="640"
        WindowStartupLocation="CenterScreen"
        Background="#F5F0E8">
    <Window.Resources>
        <SolidColorBrush x:Key="BrownDark" Color="#4E342E"/>
        <SolidColorBrush x:Key="BrownMid" Color="#6D4C41"/>
        <SolidColorBrush x:Key="BeigePanel" Color="#EDE6DD"/>
        <SolidColorBrush x:Key="Surface" Color="#FFFBF7"/>
        <SolidColorBrush x:Key="BorderTan" Color="#D7CCC8"/>
        <SolidColorBrush x:Key="MutedBrown" Color="#5D4E47"/>
    </Window.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BrownDark}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="White" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="FLOOR ASSISTANT · Clock-in"/>
                <TextBlock x:Name="PlantHeaderText" Grid.Column="1" Margin="16,0,12,0"
                           Foreground="#E8DED4" VerticalAlignment="Center"
                           Text="Plant: —"/>
                <Button x:Name="SignOutButton" Grid.Column="2" Padding="12,4"
                        Background="{StaticResource BrownMid}" Foreground="White" BorderThickness="0"
                        Content="Sign out" Click="SignOut_Click"
                        IsEnabled="False"/>
            </Grid>
        </Border>

        <Border x:Name="SignInPanel" Grid.Row="1" Background="{StaticResource Surface}" Padding="16,12"
                BorderBrush="{StaticResource BorderTan}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource BrownDark}"
                           Text="Sign in to use clock-in"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="LoginBadgeBox" Grid.Column="0" Padding="8,6"
                             BorderBrush="{StaticResource BorderTan}"
                             ToolTip="Try E001, E002, or any badge"/>
                    <Button Grid.Column="1" Margin="12,0,0,0" Padding="16,6" Content="Sign in"
                            Background="{StaticResource BrownMid}" Foreground="White" BorderThickness="0"
                            Click="SignIn_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="SessionPanel" Grid.Row="2" Background="{StaticResource BeigePanel}" Padding="16,10"
                BorderBrush="{StaticResource BorderTan}" BorderThickness="0,0,0,1" Visibility="Collapsed">
            <TextBlock x:Name="SessionText" FontWeight="SemiBold" Foreground="{StaticResource BrownDark}"
                       Text="LOGGED IN AS: —"/>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource Surface}" Padding="16,12"
                BorderBrush="{StaticResource BorderTan}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource BrownDark}"
                           Text="Clock in employee"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource MutedBrown}" Text="Badge"/>
                    <TextBox x:Name="ClockInBadgeBox" Grid.Column="1" Padding="8,6"
                             BorderBrush="{StaticResource BorderTan}"
                             IsEnabled="False"/>
                    <Button x:Name="ClockInButton" Grid.Column="2" Margin="12,0,0,0"
                            Padding="16,6" Content="Clock in" IsEnabled="False"
                            Background="{StaticResource BrownMid}" Foreground="White" BorderThickness="0"
                            Click="ClockIn_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="4" Margin="16,12,16,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FloorCountText" Grid.Column="0" FontWeight="SemiBold" FontSize="15"
                       Foreground="{StaticResource BrownDark}" Text="ON FLOOR (0)"/>
            <Button Grid.Column="1" Padding="12,4" Content="Clear all"
                    Background="{StaticResource BrownMid}" Foreground="White" BorderThickness="0"
                    Click="ClearList_Click"/>
        </Grid>

        <Border Grid.Row="5" Margin="16,0,16,16" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource BorderTan}" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="OnFloorList" BorderThickness="0" Padding="4"
                     DisplayMemberPath="ListLabel"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </Border>
    </Grid>
</Window>
