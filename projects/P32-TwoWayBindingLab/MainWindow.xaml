<Window x:Class="PracticeFA.P32.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P32 — TwoWay binding lab"
        Height="520" Width="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Edit form — TwoWay bindings -->
        <StackPanel Grid.Column="0">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Employee edit (bound)"/>
            <TextBlock Margin="0,4,0,16" Foreground="#555" TextWrapping="Wrap"
                       Text="Type in fields — preview updates live (UpdateSourceTrigger=PropertyChanged)."/>

            <TextBlock Margin="0,0,0,4" Text="Badge ID"/>
            <TextBox Margin="0,0,0,12" Padding="8,6"
                     Text="{Binding BadgeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Margin="0,0,0,4" Text="Display name"/>
            <TextBox Margin="0,0,0,12" Padding="8,6"
                     Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Margin="0,0,0,4" Text="Department / work center"/>
            <TextBox Margin="0,0,0,12" Padding="8,6"
                     Text="{Binding Department, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Margin="0,0,0,4" Text="Quantity"/>
            <TextBox Margin="0,0,0,16" Padding="8,6"
                     Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Orientation="Horizontal">
                <Button Margin="0,0,8,0" Padding="14,8" Content="Save snapshot"
                        Click="SaveSnapshot_Click"/>
                <Button Padding="14,8" Content="Revert"
                        Click="Revert_Click"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" Margin="0,12,0,0" Foreground="#0066AA" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Live preview — read-only bindings -->
        <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4"
                Padding="16" Background="#FAFAFA">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" FontSize="16" Text="Live preview"/>
                <TextBlock Margin="0,12,0,4" Foreground="#666" Text="Badge"/>
                <TextBlock FontSize="16" Text="{Binding BadgeId}"/>

                <TextBlock Margin="0,12,0,4" Foreground="#666" Text="Name"/>
                <TextBlock FontSize="16" Text="{Binding DisplayName}"/>

                <TextBlock Margin="0,12,0,4" Foreground="#666" Text="Department"/>
                <TextBlock FontSize="16" Text="{Binding Department}"/>

                <TextBlock Margin="0,12,0,4" Foreground="#666" Text="Quantity"/>
                <TextBlock FontSize="16" Text="{Binding Quantity}"/>

                <TextBlock Margin="0,20,0,0" FontSize="11" Foreground="#888" TextWrapping="Wrap"
                           Text="Preview uses same DataContext. PropertyChanged on the model refreshes these TextBlocks as you type."/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
