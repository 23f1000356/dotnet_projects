<Page x:Class="PracticeFA.App.Pages.MasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:PracticeFA.App.Controls"
      Title="Master">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Master"/>
            <TextBlock Margin="0,8,0,12" Style="{StaticResource SubtitleStyle}"
                       Text="P07 modules · P08 Employee CRUD (stored procedures only)."/>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                               Text="Your modules (from database)"/>
                    <TextBlock x:Name="ModulesListText" Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                               Text="Your modules: (not loaded)"/>
                </StackPanel>
            </Border>

            <controls:EmployeeSearchBox
                BadgeText="{Binding SearchBadge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                SearchRequested="EmployeeSearch_SearchRequested"/>

            <TextBlock x:Name="SearchResultText" Margin="0,0,0,16"
                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                       Text="Search: (none)"/>

            <TextBlock FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                       Text="Module launcher (P04 + P07)"/>
            <WrapPanel Margin="0,12,0,0">
                <Button x:Name="StyleCreationButton" Tag="1001"
                        Content="Style Creation (1001)" Click="StyleCreation_Click"/>
                <Button x:Name="BaggingEntryButton" Tag="2001"
                        Content="Bagging Entry (2001)" Click="BaggingEntry_Click"/>
                <Button x:Name="MisProductivityButton" Tag="3001"
                        Content="MIS Productivity (3001)" Click="MisProductivity_Click"/>
                <Button x:Name="EmployeeMaintenanceButton" Tag="6001"
                        Content="Employee maintenance (6001)" Click="EmployeeMaintenance_Click"/>
            </WrapPanel>

            <TextBlock x:Name="LastDialogText" Margin="0,20,0,0"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap" Text="Last dialog: (none)"/>
        </StackPanel>
    </ScrollViewer>
</Page>
