<Page x:Class="PracticeFA.App.Pages.MasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Master">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Master"/>
            <TextBlock Margin="0,8,0,20" Foreground="#555" TextWrapping="Wrap"
                       Text="Product master data hub — style, SKU, customers. In FA this is a Pages/* launcher that opens Views/* windows (P04)."/>

            <TextBlock FontWeight="SemiBold" Text="Module shortcuts (placeholders)"/>
            <WrapPanel Margin="0,12,0,0">
                <Button Margin="0,0,8,8" Padding="14,10" Content="Style Creation"
                        Click="Placeholder_Click" Tag="Style Creation"/>
                <Button Margin="0,0,8,8" Padding="14,10" Content="SKU Creation"
                        Click="Placeholder_Click" Tag="SKU Creation"/>
                <Button Margin="0,0,8,8" Padding="14,10" Content="Customer Master"
                        Click="Placeholder_Click" Tag="Customer Master"/>
                <Button Margin="0,0,8,8" Padding="14,10" Content="Employee Mapping"
                        Click="Placeholder_Click" Tag="Employee Mapping"/>
            </WrapPanel>

            <TextBlock Margin="0,24,0,0" FontSize="12" Foreground="#888"
                       Text="P01 clock-in lives in projects/P01-ClockInBoard. P04 will open real feature windows from here."/>
        </StackPanel>
    </ScrollViewer>
</Page>
