<Page x:Class="PracticeFA.App.Views.AttendanceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:PracticeFA.App.Controls"
      Title="Attendance">

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Attendance"/>
            <TextBlock Margin="0,8,0,16" Style="{StaticResource SubtitleStyle}"
                       Text="P05 MVVM + P20 busy overlay + P38 converters — async load keeps UI responsive."/>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="New row"
                            Command="{Binding NewRecordCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="SemiBold"/>

            <DataGrid ItemsSource="{Binding Records}"
                      SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                      MinHeight="160" Margin="0,0,0,16">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding AttendanceId}" Width="50"/>
                    <DataGridTextColumn Header="Badge" Binding="{Binding BadgeId}" Width="80"/>
                    <DataGridTextColumn Header="Work date" Binding="{Binding WorkDate, Converter={StaticResource DateTimeDisplayConverter}, ConverterParameter=d}" Width="100"/>
                    <DataGridTextColumn Header="Clock in" Binding="{Binding ClockInAt, Converter={StaticResource DateTimeDisplayConverter}}" Width="*"/>
                    <DataGridTextColumn Header="Clock out" Binding="{Binding ClockOutAt, Converter={StaticResource DateTimeDisplayConverter}}" Width="*"/>
                    <DataGridTextColumn Header="Weight" Binding="{Binding WeightGm, Converter={StaticResource DecimalWeightConverter}}" Width="100"/>
                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Badge ID"/>
                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,6,8,12"
                             Text="{Binding EditBadgeId, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Work date"/>
                    <DatePicker Grid.Row="1" Grid.Column="1" Margin="0,6,0,12"
                                SelectedDate="{Binding EditWorkDate}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Clock-in (HH:mm)"/>
                    <TextBox Grid.Row="3" Grid.Column="0" Margin="0,6,8,12"
                             Text="{Binding EditClockIn, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Clock-out (HH:mm, optional)"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,6,0,12"
                             Text="{Binding EditClockOut, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="Notes"/>
                    <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,0"
                             Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>

    <controls:BusyOverlay IsBusy="{Binding IsBusy}" Message="{Binding BusyMessage}"/>
    </Grid>
</Page>
