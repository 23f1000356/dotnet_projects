<Page x:Class="PracticeFA.App.Views.OrdersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:PracticeFA.App.Controls"
      Title="Orders">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource PageTitleStyle}" Text="Orders (master-detail)"/>
        <TextBlock Grid.Row="1" Margin="0,8,0,12" Style="{StaticResource SubtitleStyle}"
                   Text="P40 — select header (master) to load lines (detail). Save creates new order via P36 spSaveOrder."/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryDarkBrush}" Text="Orders (master)"/>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Refresh" Command="{Binding RefreshHeadersCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="New order"
                                Command="{Binding NewOrderCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    </StackPanel>
                    <ListView Margin="0,8,0,8" ItemsSource="{Binding Headers}"
                              SelectedItem="{Binding SelectedHeader, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayLabel}"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding OperatorBadge, StringFormat=Operator {0}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource PrimaryDarkBrush}"
                               Text="Order detail (lines)"/>

                    <Grid Grid.Row="1" Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Bag tag"/>
                            <TextBox Text="{Binding BagTag, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Operator badge"/>
                            <TextBox Text="{Binding OperatorBadge, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Plant"/>
                            <TextBox Text="{Binding PlantCode, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Lines}" MinHeight="140"
                              AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding LineNumber}" Width="40"/>
                            <DataGridTextColumn Header="SKU / style" Binding="{Binding SkuOrStyle}" Width="*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Margin="0,8,0,0">
                        <TextBlock FontWeight="SemiBold" Text="{Binding DetailTotalDisplay}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Add line" Command="{Binding AddLineCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Remove last"
                                    Command="{Binding RemoveLineCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                            <Button Content="Save order" Command="{Binding SaveOrderCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Margin="0,12,0,0" Text="{Binding StatusMessage}"
                   TextWrapping="Wrap" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryDarkBrush}"/>

        <controls:BusyOverlay Grid.RowSpan="4"
                              IsBusy="{Binding IsBusy}"
                              Message="{Binding BusyMessage}"/>
    </Grid>
</Page>
