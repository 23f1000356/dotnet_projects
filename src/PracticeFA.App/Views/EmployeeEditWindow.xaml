<Window x:Class="PracticeFA.App.Views.EmployeeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee"
        Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Style="{StaticResource PageTitleStyle}" Text="Employee"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Text="Badge ID *"/>
            <TextBox x:Name="BadgeIdBox" Margin="0,6,0,12" Padding="8,6"/>

            <TextBlock Text="Display name *"/>
            <TextBox x:Name="DisplayNameBox" Margin="0,6,0,12" Padding="8,6"/>

            <TextBlock Text="Process center"/>
            <TextBox x:Name="ProcessCenterBox" Margin="0,6,0,12" Padding="8,6"/>

            <CheckBox x:Name="IsActiveCheck" Content="Active" IsChecked="True" Margin="0,0,0,8"/>

            <TextBlock x:Name="AuditText" Margin="0,0,0,8"
                       Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                       TextWrapping="Wrap" Visibility="Collapsed"/>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Margin="0,0,8,0" Content="Save" Click="Save_Click"/>
            <Button Content="Cancel" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
