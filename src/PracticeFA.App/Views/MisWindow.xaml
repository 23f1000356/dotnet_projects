<Window x:Class="PracticeFA.App.Views.MisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MIS Productivity"
        Height="320" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" Style="{StaticResource PageTitleStyle}"
                   Text="MIS Productivity"/>
        <TextBlock Grid.Row="1" Margin="0,8,0,16" Style="{StaticResource SubtitleStyle}"
                   Text="Read-only MIS feature placeholder — P13 adds date range + SQL grid."/>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Work center filter"/>
            <TextBox x:Name="InputTextBox" Margin="0,6,0,0" Padding="8,6"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Click="Save_Click"/>
            <Button Content="Cancel" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
