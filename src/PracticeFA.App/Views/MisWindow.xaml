<Window x:Class="PracticeFA.App.Views.MisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MIS Productivity"
        Height="420" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource ModuleIdBadgeStyle}">
                    <TextBlock x:Name="ModuleBadgeText" FontWeight="Bold" Foreground="White" Text="3001"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock x:Name="HeaderText" Style="{StaticResource ModuleHeaderTitleStyle}"
                               Text="MIS Productivity"/>
                    <TextBlock Foreground="{StaticResource HeaderSubtitleOnDarkBrush}" FontSize="12"
                               Text="Reports · filters · read-only dashboards (P13 adds SQL)"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,12,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource PrimaryDarkBrush}"
                               Text="Filters"/>
                    <TextBlock Margin="0,8,0,4" Text="Work center"/>
                    <TextBox x:Name="InputTextBox"/>
                    <TextBlock Margin="0,12,0,4" Text="Shift date"/>
                    <DatePicker x:Name="ShiftDatePicker"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="8,0,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="16">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontSize="28" HorizontalAlignment="Center"
                               Foreground="{StaticResource PrimaryBrush}" Text="📊"/>
                    <TextBlock Margin="0,8,0,0" TextAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"
                               Text="Chart placeholder — MIS module"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="16,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Apply filter" Click="Save_Click"/>
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Close" Click="Cancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
