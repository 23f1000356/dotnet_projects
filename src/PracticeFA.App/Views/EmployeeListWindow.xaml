<Window x:Class="PracticeFA.App.Views.EmployeeListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee maintenance"
        Height="640" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource ModuleIdBadgeStyle}">
                    <TextBlock x:Name="ModuleBadgeText" FontWeight="Bold" Foreground="White" Text="6001"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock x:Name="HeaderText" Style="{StaticResource ModuleHeaderTitleStyle}"
                               Text="Employee maintenance"/>
                    <TextBlock Foreground="{StaticResource HeaderSubtitleOnDarkBrush}" FontSize="12"
                               Text="P38 — MultiBinding label, BoolToVisibility inactive badge, DataTrigger row style"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="16,12,16,0" Style="{StaticResource CardBorderStyle}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Badge contains"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Margin="12,0,0,0" Text="Process center contains"/>
                <TextBox x:Name="BadgeFragmentBox" Grid.Row="1" Grid.Column="0" Margin="0,6,0,0"/>
                <TextBox x:Name="ProcessCenterBox" Grid.Row="1" Grid.Column="1" Margin="12,6,0,0"/>
                <CheckBox x:Name="ActiveOnlyCheck" Grid.Row="1" Grid.Column="2" Margin="16,6,0,0"
                          VerticalAlignment="Center" IsChecked="True" Content="Active only"/>
                <Button Grid.Row="1" Grid.Column="3" Margin="16,6,0,0" Padding="16,8"
                        Content="Search" Click="Search_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="16,8,16,0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,3" Padding="12,10">
            <StackPanel Orientation="Horizontal">
                <Button Margin="0,0,8,0" Content="Refresh" Click="Refresh_Click"/>
                <Button Margin="0,0,8,0" Content="Add" Click="Add_Click"/>
                <Button Margin="0,0,8,0" Content="Edit" Click="Edit_Click"/>
                <Button Margin="0,0,8,0" Background="{StaticResource ErrorBrush}"
                        Content="Delete" Click="Delete_Click"/>
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Close" Click="Close_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Margin="16,8,16,0" Style="{StaticResource CardBorderStyle}">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="NoRecordsText" DockPanel.Dock="Top" Visibility="Collapsed"
                           Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#B00020"
                           Text="No records — try clearing filters or include inactive employees."/>
                <DataGrid x:Name="EmployeeGrid" BorderThickness="0"
                          SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="True"
                          AutoGenerateColumns="False">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                    <Setter Property="Background" Value="#FFF0EBE9"/>
                                    <Setter Property="Foreground" Value="#FF8D6E63"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Employee" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource EmployeeLabelConverter}">
                                                    <Binding Path="BadgeId"/>
                                                    <Binding Path="DisplayName"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="3"
                                                Background="{StaticResource ErrorBrush}"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                            <TextBlock Text="INACTIVE" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Center" Binding="{Binding ProcessCenter}" Width="120"/>
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                        <DataGridTextColumn Header="Created by" Binding="{Binding CreatedBy}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="4" Margin="16,8,16,16" Padding="0,8,0,0">
            <TextBlock x:Name="StatusText"
                       Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
