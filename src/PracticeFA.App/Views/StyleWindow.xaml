<Window x:Class="PracticeFA.App.Views.StyleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Style Creation"
        Height="520" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinHeight="480" MinWidth="520"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource ModuleIdBadgeStyle}">
                    <TextBlock x:Name="ModuleBadgeText" FontWeight="Bold" Foreground="White" Text="1001"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock x:Name="HeaderText" Style="{StaticResource ModuleHeaderTitleStyle}"
                               Text="Style Creation"/>
                    <TextBlock Foreground="{StaticResource HeaderSubtitleOnDarkBrush}" FontSize="12"
                               Text="Save style code and description to PracticeFA database"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="16,16,16,0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource PrimaryDarkBrush}"
                           Text="Style record"/>
                <TextBlock Margin="0,4,0,8" Style="{StaticResource SubtitleStyle}"
                           Text="Enter code and description, then Save. Re-using a code updates the description."/>
                <TextBlock Text="Style code"/>
                <TextBox x:Name="StyleCodeBox" Margin="0,6,0,10"/>
                <TextBlock Text="Description"/>
                <TextBox x:Name="DescriptionBox" Margin="0,6,0,8" Height="64"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                <TextBlock x:Name="ErrorText" Foreground="#B00020" TextWrapping="Wrap" Margin="0,0,0,4"/>
                <Border x:Name="SavedPanel" Visibility="Collapsed" Background="#E8F5E9" Padding="10" CornerRadius="4"
                        BorderBrush="#81C784" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource PrimaryDarkBrush}"
                                   Text="Saved to database"/>
                        <TextBlock x:Name="SavedCodeText" Margin="0,4,0,2" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SavedDescriptionText" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="16,12,16,0" Style="{StaticResource CardBorderStyle}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Foreground="{StaticResource PrimaryDarkBrush}"
                           Margin="0,0,0,8" Text="Styles in database"/>
                <TextBlock x:Name="GridStatusText" DockPanel.Dock="Bottom" Margin="0,8,0,0"
                           Style="{StaticResource SubtitleStyle}" Text="Loading…"/>
                <DataGrid x:Name="StylesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" SelectionChanged="StylesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Style code" Binding="{Binding StyleCode}" Width="120"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Padding="16,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Click="Save_Click"/>
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Close" Click="Cancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
