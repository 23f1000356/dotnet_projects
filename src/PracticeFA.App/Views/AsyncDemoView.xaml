<Page x:Class="PracticeFA.App.Views.AsyncDemoView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:PracticeFA.App.Controls"
      Title="Async demo">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource PageTitleStyle}" Text="Async + busy overlay"/>
        <TextBlock Grid.Row="1" Margin="0,8,0,12" Style="{StaticResource SubtitleStyle}"
                   Text="P20 — FA pattern: slow work on background thread; overlay + disabled buttons keep UI responsive (replaces BackgroundWorker)."/>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="Load (slow ~3s)"
                        Command="{Binding LoadSlowCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                <TextBlock Margin="16,8,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="Click repeatedly while loading — window should not freeze."/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Rows}" MinHeight="200"
                  AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Order #" Binding="{Binding OrderId}" Width="80"/>
                <DataGridTextColumn Header="Bag tag" Binding="{Binding BagTag}" Width="*"/>
                <DataGridTextColumn Header="Total qty" Binding="{Binding TotalQuantity}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4" Margin="0,12,0,0" Text="{Binding StatusMessage}"
                   TextWrapping="Wrap" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryDarkBrush}"/>

        <controls:BusyOverlay Grid.RowSpan="5"
                              IsBusy="{Binding IsBusy}"
                              Message="{Binding BusyMessage}"/>
    </Grid>
</Page>
