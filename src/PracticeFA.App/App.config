<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <!-- P24 — switch target without recompile:
       1) Edit connection strings below, OR
       2) Set env PRACTICE_FA_ENV=QA to use PracticeFA_QA, OR
       3) Set env PRACTICE_FA_CONNECTION=PracticeFA_QA (explicit name) -->
  <connectionStrings>
    <add name="PracticeFA"
         connectionString="Server=(localdb)\MSSQLLocalDB;Database=PracticeFA;Trusted_Connection=True;TrustServerCertificate=True;"
         providerName="Microsoft.Data.SqlClient" />
    <add name="PracticeFA_QA"
         connectionString="Server=.;Database=PracticeFA;Trusted_Connection=True;TrustServerCertificate=True;"
         providerName="Microsoft.Data.SqlClient" />
  </connectionStrings>
</configuration>
